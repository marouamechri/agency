<main id="main">
	<h1>Appointement</h1>
	<div><a href="{{ path('app_appointement_new') }}"  class="btn btn-primary mt-3">ajouter RDV </a></div>
	<table class="table table-striped">
		<thead>
			<tr>
				<th scope="col">Id</th>
				<th scope="col">Date</th>
				<th scope="col">Email</th>
				<th scope="col">Tel</th>
				<th scope="col">Nom</th>
				<th scope="col">Prenom</th>
				<th scope="col">actions</th>
			</tr>
		</thead>
		<tbody>
			{% for appointement in appointements %}
				<tr>
					<td scope="row">{{ appointement.id }}</td>
					<td>{{ appointement.date ? appointement.date|date('Y-m-d H:i:s') : '' }}</td>
					<td>{{ appointement.email }}</td>
					<td>{{ appointement.tel }}</td>
					<td>{{ appointement.nom }}</td>
					<td>{{ appointement.prenom }}</td>
					<td>
						<a href="{{ path('app_appointement_edit', {'id': appointement.id}) }}">edit</a>
						{{ include('appointement/_delete_form.html.twig') }}
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="7">il n'y a pas des rendez-vous</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
</main>
