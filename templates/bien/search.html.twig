{% extends 'base.html.twig' %}

{% block title %}search
{% endblock %}
{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('css/styleindex.css') }}" type="text/css"/>
{% endblock %}

{% block body %}
	<div class="container">
		<div id="divsearch" class="row">
			<div class="col-12">
				{% include 'bien/_filter.html.twig' %}
			</div>
		</div>
		<div class="row">
			<div class="container">
				<div id="grid" class="grid">
					{% for bien in biens %}
						{% include 'bien/_card.html.twig' with {bien:bien} only %}
					{% else %}
						<p>il y'a pas des annonces</p>
					{% endfor %}
				</div>
			</div>
			<nav aria-label="Page-navigation">
				<ul class="pagination justify-content-end pagination-sm">
					{% for item in 1..((total/limit)|round(0, 'ceil')) %}
						{% if (page == item) %}
							{% set disabled = 'disabled' %}
							{% set tabindex = 'tabindex="-1"' %}
						{% else %}
							{% set disabled = '' %}
							{% set tabindex = '' %}
						{% endif %}
						<li class="page-item {{disabled}}">
							<a class="page-link" {{tabindex}} href="?page={{item}}">{{item}}</a>
						</li>
					{% endfor %}
				</ul>
			</nav>
		</div>
	</div>
{% endblock %}
